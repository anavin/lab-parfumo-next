# ============================================================
# Supabase — copy ค่าจาก project ที่ใช้งานอยู่ใน Streamlit
# Settings → API → Project URL + service_role key
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGc..."

# ⚠️ Service role — ห้ามใส่ใน client! ใช้ Server Action / Server Component เท่านั้น
SUPABASE_SERVICE_ROLE_KEY="eyJhbGc..."

# ============================================================
# SMTP — Welcome email (optional)
# ============================================================
# ถ้าไม่ตั้ง — ระบบจะข้ามการส่งอีเมลโดยไม่ error
# Gmail: ใช้ "App Password" — https://myaccount.google.com/apppasswords
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# FROM_EMAIL="your-email@gmail.com"
# FROM_NAME="Lab Parfumo PO"

# ============================================================
# Public app URL (ใช้ใน email link "เข้าสู่ระบบ")
# ============================================================
# NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ============================================================
# Security keys (recommended)
# ============================================================
# Cron auth — required for /api/cron/daily-digest
# generate: openssl rand -hex 32
# CRON_SECRET=""
#
# SMTP password encryption (AES-256-GCM)
# If not set → plaintext fallback + UI warning in /settings
# generate: openssl rand -hex 32
# ENCRYPTION_KEY=""

# ============================================================
# Sentry — error tracking (optional, recommended for production)
# ถ้าไม่ตั้ง — ระบบทำงานปกติ ไม่ส่งรายงาน error
# Sign up: https://sentry.io → Create project (Next.js) → copy DSN
# ============================================================
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
